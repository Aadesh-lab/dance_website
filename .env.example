##
## Backend env — copy to `.env` and fill in for local runs.
## On Railway, set these as service variables (leave this file untouched).
##

# Server
PORT=8080
ENV=development

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=lldance
DB_PASSWORD=lldance
DB_NAME=lldance
DB_SCHEMA=public

# Auth
JWT_SECRET=change-me-in-prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# MinIO / S3
# For local docker-compose, use "localhost:9000" (or the container name if
# calling from another container). On Railway, use the internal MinIO host.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=llmdance123#
MINIO_BUCKET=lldance

# The public URL browsers hit for uploaded files. Locally: same as endpoint
# with scheme. On Railway: the MinIO service's public domain.
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

# First-boot asset seed. Docker image sets this to /app/assets automatically.
# Unset to skip seeding (e.g. for local `go run` when you don't want uploads).
ASSETS_DIR=./assets
